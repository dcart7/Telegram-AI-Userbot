group_id: -100XXXXXXXXXXXX

# Option C: multiple groups (if set, group_id/prompt/delays above are ignored)
groups:
  - group_id: -1001111111111
    prompt: "Group of friends discussing startups and technology"
    delay_min: 10
    delay_max: 40
  - group_id: -1002222222222
    prompt: "Casual chat about music, movies, and everyday life"
    delay_min: 12
    delay_max: 45

# Option A: string sessions (Telethon StringSession)
sessions:
  - "<STRING_SESSION_1>"
  - "<STRING_SESSION_2>"
  - "<STRING_SESSION_3>"
  - "<STRING_SESSION_4>"
  - "<STRING_SESSION_5>"

# Option B: path to .session files (Telethon SQLite sessions)
session_paths:
  - "/full/path/to/first.session"
  - "/full/path/to/second.session"
  - "/full/path/to/third.session"
  - "/full/path/to/fourth.session"
  - "/full/path/to/fifth.session"

# Admin selection:
# Either set admin_session to match one entry above, or set admin_index.
admin_session: "<STRING_SESSION_1>"
admin_index: -1

delay_min: 10
delay_max: 40

prompt: "Group of friends discussing startups and technology"

context_max_messages: 25
max_context_chars: 1200
prompt_mode: "compact"
reply_to_last_probability: 0.25
emoji_probability: 0.25
emoji_force_probability: 0.0
emoji_emotional_insert_probability: 0.5
emoji_mid_probability: 0.35
short_reply_probability: 0.5
gif_probability: 0.12
reaction_probability: 0.12
reaction_emojis:
  - "👍"
  - "😂"
  - "🤔"
  - "😍"
  - "❤️"

# More natural typing simulation (seconds and speed)
typing_base_min: 0.4
typing_base_max: 1.6
typing_min_delay: 0.8
typing_max_delay: 8.0
typing_chars_per_second_min: 8.0
typing_chars_per_second_max: 18.0

# Sometimes split a reply into two parts
split_message_probability: 0.18
split_min_chars: 50
split_max_chars: 240

# Contextual emojis for message tone (optional)
emoji_context_map:
  angry: ["😡", "😠"]
  happy: ["😄", "😁", "😅"]
  sad: ["😔", "🥲"]
  question: ["🤔", "❓"]
  surprise: ["😮", "🤯"]
  agree: ["✅", "👍"]
  neutral: ["🙂"]

# Contextual reactions (optional)
reaction_context_map:
  angry: ["😡", "😠"]
  happy: ["😂", "😁", "👍"]
  sad: ["😔", "🥲"]
  question: ["🤔", "❓"]
  surprise: ["😮", "🤯"]
  agree: ["👍", "✅"]
  neutral: ["🙂", "👀"]

# Scale control (max parallel LLM requests)
max_parallel_requests: 4

# Optional: per-bot personas in the same order as sessions/session_paths
bot_personas:
  - "Thoughtful and playful; reflects a bit, then shares lighthearted everyday AI uses."
  - "Skeptical and pragmatic; questions hype and focuses on limitations and tradeoffs."
  - "Occasionally drifts off-topic in a natural way, then gently brings it back."
  - "Mysterious and enigmatic; speaks in short, intriguing hints."
  - "Bold and a bit unhinged; energetic, playful, and impulsive."

# Optional: Redis for shared context storage
redis_url: "redis://localhost:6379/0"
redis_key_prefix: "tg_userbot"

# xAI model to use (examples: grok-3-fast)
xai_model: "grok-3-fast"

# Optional: list of fallback GIF URLs
gif_urls:
  - "https://media.giphy.com/media/3o7TKtnuHOHHUjR38Y/giphy.gif"
  - "https://media.giphy.com/media/l0MYt5jPR6QX5pnqM/giphy.gif"
  - "https://media.giphy.com/media/3o7btPCcdNniyf0ArS/giphy.gif"

# Contextual GIFs by tone (optional)
gif_tone_probability: 1.0
gif_context_map:
  angry:
    - "https://media.giphy.com/media/11tTNkNy1SdXGg/giphy.gif"
    - "https://media.giphy.com/media/l1J9u3TZfpmeDLkD6/giphy.gif"
  happy:
    - "https://media.giphy.com/media/26ufdipQqU2lhNA4g/giphy.gif"
    - "https://media.giphy.com/media/3o7TKSjRrfIPjeiVy8/giphy.gif"
  laugh:
    - "https://media.giphy.com/media/3o6Zt481isNVuQI1l6/giphy.gif"
    - "https://media.giphy.com/media/1r91ZwKcE2J7WhUqrh/giphy.gif"
  sad:
    - "https://media.giphy.com/media/ROF8OQvDmxytW/giphy.gif"
  surprise:
    - "https://media.giphy.com/media/12NUbkX6p4xOO4/giphy.gif"
  agree:
    - "https://media.giphy.com/media/111ebonMs90YLu/giphy.gif"
  question:
    - "https://media.giphy.com/media/3o7btPCcdNniyf0ArS/giphy.gif"
  neutral:
    - "https://media.giphy.com/media/3o7TKtnuHOHHUjR38Y/giphy.gif"
